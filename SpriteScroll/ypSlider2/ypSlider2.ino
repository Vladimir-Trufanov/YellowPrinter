#include <TFT_eSPI.h>
#include <TFT_eWidget.h> // Для виджетов (слайдера)

TFT_eSPI tft = TFT_eSPI();
TFT_eSprite knob = TFT_eSprite(&tft); // Sprite для ручки слайдера
SliderWidget s1 = SliderWidget(&tft, &knob); // Первый слайдер
// SliderWidget s2 = SliderWidget(&tft, &knob); // Второй (можно использовать тот же спрайт)

void setup() 
{
  Serial.begin(115200);
  tft.begin();
  tft.fillScreen(TFT_BLACK);

  // Создаём параметры для слайдера
  slider_t param;
  param.slotWidth = 9; // Ширина прорези
  param.slotLength = 200; // Длина прорези

  // Рисуем слайдер в точке (0, 0)
  s1.drawSlider(0, 0, param);

  // Можно добавить второй слайдер
  // s2.drawSlider(0, 50, param);

  // Для отладки: покажем ограничивающую рамку (1 пиксель снаружи рабочей области)
  int16_t x, y; // Координаты
  uint16_t w, h; // Ширина и высота
  s1.getBoundingRect(&x, &y, &w, &h);
  tft.drawRect(x, y, w, h, TFT_DARKGREY);
}

void loop() 
{
  // Опрашиваем касания
  int16_t t_x, t_y;
  if (tft.getTouch(&t_x, &t_y, 250)) {
    if (s1.checkTouch(t_x, t_y)) {
      // Слайдер активен — выводим текущее значение
      Serial.print("Slider 1 = ");
      Serial.println(s1.getSliderPosition());
    }
    // Можно добавить проверку для s2, если нужен второй слайдер
  }
}
